# Astro Backend Environment Variables
# Copy this file to .env and fill in your values

# ============================================================================
# Database Configuration
# ============================================================================

# MongoDB connection URI
# For local development, use the default
# For production, use your MongoDB Atlas URI or production server
MONGO_URI=mongodb://localhost:27017

# Database name to use
MONGO_DB=astro

# ============================================================================
# LLM Configuration  
# ============================================================================

# OpenAI API Key (REQUIRED)
# Get your API key from https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# LLM model to use (optional, defaults to gpt-4-turbo-preview)
# Options: gpt-4-turbo-preview, gpt-4, gpt-3.5-turbo, etc.
LLM_MODEL=gpt-4-turbo-preview

# ============================================================================
# Security Configuration
# ============================================================================

# CORS Allowed Origins (comma-separated)
# CRITICAL: Set this to your frontend domain(s) in production
# Examples:
#   Development: http://localhost:3000
#   Production: https://yourdomain.com,https://app.yourdomain.com
#   Multiple: https://domain1.com,https://domain2.com
ALLOWED_ORIGINS=http://localhost:3000

# ============================================================================
# Optional: Rate Limiting (if implemented)
# ============================================================================

# Maximum requests per minute per IP
# RATE_LIMIT_PER_MINUTE=60

# ============================================================================
# Optional: Logging Configuration
# ============================================================================

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
# LOG_LEVEL=INFO

# ============================================================================
# Notes for Production Deployment
# ============================================================================
#
# 1. Never commit .env file to version control
# 2. Use strong, unique API keys
# 3. Set ALLOWED_ORIGINS to your actual domain(s)
# 4. Consider using a secrets manager (AWS Secrets Manager, Azure Key Vault, etc.)
# 5. Enable MongoDB authentication in production
# 6. Use HTTPS for all external communication
# 7. Regularly rotate API keys and credentials
#
